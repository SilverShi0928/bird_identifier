# --- 影像辨識（OpenAI 相容 Chat Completions + vision）---
BIRD_VISION_API_KEY=your_key_here
# 選填：基底網址；留空則用程式內建預設
# BIRD_VISION_BASE_URL=
# 須支援圖像輸入嘅模型 id（按服務商目錄填寫）
BIRD_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct
# 選填：多後端路由時要跳過嘅供應商代號（逗號分隔、小寫）；留空行為見程式預設
BIRD_VISION_PROVIDER_IGNORE=novita
# 選填：部分網關會檢查嘅歸因標頭
BIRD_VISION_HTTP_REFERER=https://github.com/local/bird_identifier
BIRD_VISION_APP_TITLE=雀鳥辨識

REQUEST_TIMEOUT_SECONDS=30
REQUEST_RETRY_COUNT=2
TOP_K=3
MAX_UPLOAD_MB=8
MAX_IMAGE_SIDE=1600

# --- 選填：結果翻譯成繁體中文（Chat Completions 文字模型）---
BIRD_TRANSLATE_API_KEY=
# BIRD_TRANSLATE_BASE_URL=
# BIRD_TRANSLATE_MODEL=

# Optional: eBird API (recent observations per region; no LLM confirmation)
EBIRD_API_TOKEN=
EBIRD_REGIONS=HK,CN
EBIRD_RECENT_MAX=10

# Optional: MOSS-TTS-Nano (Top1 中文候選朗讀按鈕)
# Use absolute paths on Windows.
MOSS_TTS_NANO_HOME=
MOSS_TTS_CLI=
MOSS_TTS_BACKEND=onnx
MOSS_TTS_VOICE=Junhao
# Optional: reference WAV for voice clone (if set, it overrides MOSS_TTS_VOICE).
MOSS_TTS_PROMPT_SPEECH=
MOSS_TTS_TIMEOUT_SECONDS=120

# Cantonese TTS engine for 「朗讀 Top 1」
# edge = 線上粵語語音, moss = MOSS-TTS-Nano
CANTONESE_TTS_ENGINE=edge
EDGE_TTS_VOICE=yue-HK-HiuGaaiNeural

# 舊版模版用嘅其他變數名仍會讀取（優先次序以 config/settings.py 為準）。
